              "l_cm": "#1",
              "l_natural": "mã ao"
            }
          ],
          "n_content": "[#4=\"\"](D9\"không có quyền điều khiển\")\n//tính ra mã ngoại vi\nD4#5,(#1-1)*2+100+#2\n[#3=\"ON\"](D1O#5D5N101,#1,\"on\",\"bật bơm \"#2\" bằng tay\",#4)\n[#3=\"OFF\"](D2O#5D5N101,#1,\"off\",\"tắt O1 bằng tay\",#4)\nD21,#801,\"telemetry\",\"O\"#5\"=\"O#5\nD9\"Điều khiển thành công O\"#5",
