          "n_mode": "1",
          "n_local_def": [],
          "n_content": "D4#2,I105\nD4#3,I106\nD6N2,\"31,32\",#2.1,#2.8,#2.9,#2.10,#3.1,#3.8,#3.9,#3.10\n//kiểm tra tình trạng và báo lỗi\nD6,#4,N102,#2.8,#2.9,#2.10,#2.11\nD6,#5,N102,#3.8,#3.9,#3.10,#3.11\n//#6 chứa lỗi chung của 2 bơm\n[#5=\"null\"](D4#5,#4)  //#6 không lỗi thì copy từ #5\nD5N9,#2.11#3.11,#5.1,#5.2\n\nD4#5,#2.11\",\"#3.11\",\"#1002\",\"#1003\",\"#1004\",\"#1005\",\"#1006\",\"#1010\",\"#1011\",\"#1021\",\"#1022\",\"#1023\",\"#1024\n//cập nhật khi thay đổi hoặc mỗi 5 phút (60*5)\n[(#5<>#119|#1%60=0)](\n  D4#119,#5\n  D23,#801,,\"timeseries\",\"Temper31=\"#2.12,\"Temper32=\"#3.12\n  D21,#801,\"telemetry\",\"#1029=\"#1029,\"#1030=\"#1030,\"#1031=\"#1031,\"#1032=\"#1032,\"O105=\"#2.11,\"O106=\"#3.11,\"Energy31_Wh=\"#2.6,\"Energy32_Wh=\"#3.6\n)\n",
