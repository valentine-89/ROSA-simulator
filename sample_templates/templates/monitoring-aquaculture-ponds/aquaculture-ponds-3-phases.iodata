          "n_local_def": [],
          "n_content": "[#4=\"\"](D9\"disconnect\")\n[#4=\"ON\"](\n  [(#1<#1011.1|#2<#1011.1|#3<#1011.1)](D9\"shaft_break,\"#1\"|\"#2\"|\"#3)\n  [(#1>#1011.2|#2>#1011.2|#3>#1011.2)](D9\"overload,\"#1\"|\"#2\"|\"#3)\n  D6,#5,N104,#1006[#5=\"IN\"](D9\"off_time\")\n)(\n  D6,#5,N104,#1005[#5=\"IN\"](D9\"on_time\")\n)\nD9\"null\"",
