          ],
          "n_content": "[#1=\"\"](D9\"Cần đăng nhập\")\n[(#2=0|#2>4)](D9\"Mã ao phải 1-4\")\nD4#3,#2+10\nD15N#3\t\t    //tạm dừng quy trình báo động\nD21,#801,\"telemetry\",\"alarm\"#2\"=\"\t//xóa thông báo\nD6N101,#2,\"alarm_off\",#1053,#1",
