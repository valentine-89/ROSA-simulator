          "n_content": "I99-1\nW5\nL(\n  D4#103,#904-#3\n  D4#3,#904\n  [#1003.1=\"ON\"](D1O1'2'D6N41,#1D2O1[#891>0](W3)(W2))\n  [#1003.2=\"ON\"](D1O1'2'D6N42,#1D2O1[#891>0](W3)(W2))\n  [#1003.3=\"ON\"](D1O1'2'D6N43,#1D2O1[#891>0](W3)(W2))\n  [#1003.4=\"ON\"](D1O1'2'D6N44,#1D2O1[#891>0](W3)(W2))\n  [#891>10](W10)\n  [#1003<>#2|#1%60=0](\n    D4#2,#1003\n    D23,#801,,\"telemetry\",\"#1003.1=\"#1003.1,\"#1003.2=\"#1003.2,\"#1003.3=\"#1003.3,\"#1003.4=\"#1003.4\n  )\n  D4#1,#1+1\n)",
          "n_natural": "",
          "n_name": "cập nhật chung"
        },
        {
          "n_id": "2",
          "n_mode": "1",
          "n_local_def": [],
          "n_content": "//nếu 2 bơm không lỗi thì gửi chung để tiết kiệm số lần gửi\n[(#2<>\"ERROR\"&#6<>\"ERROR\")](\n  D23,#801,,\"timeseries\",\"Voltage\"#1.1\"_V=\"#2,\"Current\"#1.1\"_A1=\"#3,\"Current\"#1.1\"_A2=\"#4,\"Current\"#1.1\"_A3=\"#5,\"Voltage\"#1.2\"_V=\"#6,\"Current\"#1.2\"_A1=\"#7,\"Current\"#1.2\"_A2=\"#8,\"Current\"#1.2\"_A3=\"#9\n)(\n  [#2<>\"ERROR\"](\n    D23,#801,,\"timeseries\",\"Voltage\"#1.1\"_V=\"#2,\"Current\"#1.1\"_A1=\"#3,\"Current\"#1.1\"_A2=\"#4,\"Current\"#1.1\"_A3=\"#5\n  )\n  [#6<>\"ERROR\"](\n    D23,#801,,\"timeseries\",\"Voltage\"#1.2\"_V=\"#6,\"Current\"#1.2\"_A1=\"#7,\"Current\"#1.2\"_A2=\"#8,\"Current\"#1.2\"_A3=\"#9\n  )\n)\n",
          "n_natural": "",
          "n_name": "gửi timeseries",
          "n_desc": ""
        },
        {
          "n_id": "41",
          "n_mode": "1",
          "n_local_def": [
            {
              "l_id": 70896,
              "l_type": "variable",
              "l_cm": "#3",
              "l_natural": "thông tin bơm 2"
            },
            {
              "l_id": 75888,
              "l_type": "variable",
              "l_cm": "#2",
              "l_natural": "thông tin bơm 1"
            },
            {
              "l_id": 26011,
              "l_type": "variable",
              "l_cm": "#1",
              "l_natural": "timer đếm tới"
            }
          ],
          "n_content": "D4#2,I101\nD4#3,I102\nD6N2,\"11,12\",#2.1,#2.8,#2.9,#2.10,#3.1,#3.8,#3.9,#3.10\n//kiểm tra tình trạng và báo lỗi\nD6,#4,N102,#2.8,#2.9,#2.10,#2.11\nD6,#5,N102,#3.8,#3.9,#3.10,#3.11\n//#5 chứa lỗi chung của 2 bơm\n[#5=\"null\"](D4#5,#4)  //#5 không lỗi thì copy từ #4\nD5N7,#2.11#3.11,#5.1,#5.2\n\n//các cập nhật chậm khác\nD4#5,#2.11\",\"#3.11\",\"#1002\",\"#1003\",\"#1004\",\"#1005\",\"#1006\",\"#1010\",\"#1011\",\"#1021\",\"#1022\",\"#1023\",\"#1024\n//cập nhật khi thay đổi hoặc mỗi 5 phút (60*5)\n[(#5<>#117|#1%60=0)](\n  D4#117,#5\n  D23,#801,,\"timeseries\",\"Temper11=\"#2.12,\"Temper12=\"#3.12\n  D21,#801,\"telemetry\",\"#1021=\"#1021,\"#1022=\"#1022,\"#1023=\"#1023,\"#1024=\"#1024,\"O101=\"#2.11,\"O102=\"#3.11,\"Energy11_Wh=\"#2.6,\"Energy12_Wh=\"#3.6\n  //các tham số dùng chung nhiều ao\n  D21,#801,\"telemetry\",\"#1002=\"#1002,\"#1004=\"#1004,\"#1005=\"#1005,\"#1006=\"#1006,\"#1010=\"#1010,\"#1011=\"#1011\n)\n",
          "n_natural": "",
          "n_name": "cập nhật ao 1",
          "n_desc": ""
        },
        {
          "n_id": "42",
          "n_mode": "1",
          "n_local_def": [],
          "n_content": "D4#2,I103\nD4#3,I104\nD6N2,\"21,22\",#2.1,#2.8,#2.9,#2.10,#3.1,#3.8,#3.9,#3.10\n//kiểm tra tình trạng và báo lỗi\nD6,#4,N102,#2.8,#2.9,#2.10,#2.11\nD6,#5,N102,#3.8,#3.9,#3.10,#3.11\n//#6 chứa lỗi chung của 2 bơm\n[#5=\"null\"](D4#5,#4)  //#6 không lỗi thì copy từ #5\nD5N8,#2.11#3.11,#5.1,#5.2\n\nD4#5,#2.11\",\"#3.11\",\"#1002\",\"#1003\",\"#1004\",\"#1005\",\"#1006\",\"#1010\",\"#1011\",\"#1021\",\"#1022\",\"#1023\",\"#1024\n//cập nhật khi thay đổi hoặc mỗi 5 phút (60*5)\n[(#5<>#118|#1%60=0)](\n  D4#118,#5\n  D23,#801,,\"timeseries\",\"Temper21=\"#2.12,\"Temper22=\"#3.12\n  D21,#801,\"telemetry\",\"#1025=\"#1025,\"#1026=\"#1026,\"#1027=\"#1027,\"#1028=\"#1028,\"O103=\"#2.11,\"O104=\"#3.11,\"Energy21_Wh=\"#2.6,\"Energy22_Wh=\"#3.6\n)",
